# BeigeBox Production Environment Variables
# Copy to .env and fill in values before running docker-compose.prod.yaml.
# cp .env.prod.example .env

# ── Ports (host-side) ────────────────────────────────────────────────────────
BEIGEBOX_PORT=1337
OLLAMA_PORT=11434

# ── Data persistence paths (bind-mounted into volumes) ───────────────────────
# BeigeBox SQLite + ChromaDB. Must exist and be writable by uid 1000.
BEIGEBOX_DATA_PATH=/mnt/storage/beigebox/data

# Ollama model cache. Reuse your existing ~/.ollama or a dedicated path.
OLLAMA_DATA_PATH=/mnt/storage/ollama

# ── Config / asset paths (read-only bind mounts) ─────────────────────────────
# Absolute paths to host-side files. Defaults assume deploy/docker/ cwd.
BEIGEBOX_CONFIG_PATH=../../config.yaml
HOOKS_PATH=../../hooks
SKILLS_PATH=../../2600/skills
WASM_PATH=../../wasm_modules
WORKSPACE_OUT_PATH=../../workspace/out

# ── Ollama routing ───────────────────────────────────────────────────────────
# Service name in this compose file. Change to an IP for an external Ollama.
OLLAMA_HOST=ollama
OLLAMA_NUM_PARALLEL=3

# ── Security ─────────────────────────────────────────────────────────────────
# 64-hex-char master key for encrypting stored API tokens (connections.enc).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
BB_MASTER_KEY=

# BeigeBox API key — set to require Authorization: Bearer <key> on all endpoints.
# Leave empty to disable auth.
# BEIGEBOX_API_KEY=

# ── External API keys (optional) ─────────────────────────────────────────────
# Google Search tool
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# OpenRouter fallback backend
OPENROUTER_API_KEY=

# ── BrowserBox Chrome extension relay ────────────────────────────────────────
BROWSERBOX_WS_URL=ws://host.docker.internal:9009
