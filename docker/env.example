# BeigeBox local overrides — copy to .env and edit for your machine
# cp env.example .env
#
# QUICK REFERENCE:
#   docker compose up -d                         # full stack (CPU inference)
#   docker compose --profile voice up -d         # full stack + voice I/O
#   docker compose up -d beigebox                # proxy only, external Ollama

# ── Ports (host-side) ────────────────────────────────────────────────────────
BEIGEBOX_PORT=1337
OLLAMA_PORT=11434
WHISPER_PORT=9000
KOKORO_PORT=8880
LLAMA_CPP_PORT=8001
VLLM_PORT=8002
EXECUTORCH_PORT=8003

# ── Model Storage ─────────────────────────────────────────────────────────────
# BeigeBox resolves model paths with smart fallback:
# 1. OLLAMA_DATA (Ollama's native location, if set)
# 2. MODELS_PATH (explicit override)
# 3. model_paths list in config.yaml (priority order, first existing wins)
# 4. Default: /mnt/storage/models
#
# This allows you to:
# - Reuse Ollama's existing ~/.ollama/models (OLLAMA_DATA)
# - Have a single unified path (MODELS_PATH)
# - Support scattered models across multiple storage locations (model_paths list)

# Ollama's model directory — all backends can use these models
OLLAMA_DATA=/home/youruser/.ollama

# Explicit override for all backends (if not using OLLAMA_DATA)
# MODELS_PATH=/mnt/storage/models

# Which Ollama service to route to — matches the service name in compose
# Leave as 'ollama' for Docker stack, or set a LAN IP for remote e.g. 192.168.1.x
OLLAMA_HOST=ollama

# ── API keys ─────────────────────────────────────────────────────────────────
# Required for the Claude Code sidecar (sandbox profile)
ANTHROPIC_API_KEY=

# Only needed if using Google Search tool instead of DuckDuckGo
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# ── Web UI OAuth (optional) ───────────────────────────────────────────────────
# Only needed if auth.web_ui.mode = oauth in config.yaml
# client_id goes in config.yaml (not secret); secrets go here at runtime only
# BB_GOOGLE_CLIENT_SECRET=
# BB_SESSION_SECRET=

# ── BrowserBox ───────────────────────────────────────────────────────────────
# WebSocket URL for the BrowserBox relay. When running in Docker, the relay
# must be started with --host 0.0.0.0 so Docker can reach it.
# Default uses host.docker.internal which resolves to the host machine.
BROWSERBOX_WS_URL=ws://host.docker.internal:9009

# ── Voice (voice profile only) ───────────────────────────────────────────────
# Whisper model — larger = more accurate, slower to load
# Options: Systran/faster-whisper-tiny, base, small, medium, large-v3
WHISPER_MODEL=Systran/faster-whisper-base

# ── Alternative LLM Engines (choose one profile: engines-cpp, engines-vllm, or engines-executorch)
# Default is Ollama. To use an alternative:
#   docker compose --profile engines-cpp up -d     (llama.cpp)
#   docker compose --profile engines-vllm up -d    (vLLM)
#   docker compose --profile engines-executorch up -d (ExecutorTorch)

# llama.cpp (engines-cpp profile) — GGUF quantized models, minimal resource
# Model path: local dir or /models (mounted volume)
LLAMA_CPP_MODEL_PATH=/models
LLAMA_CPP_CONTEXT=4096
LLAMA_CPP_GPU_LAYERS=0  # Set to >0 if NVIDIA GPU available

# vLLM (engines-vllm profile) — Production inference, HuggingFace models
# Model: HuggingFace model ID (auto-downloaded on startup)
VLLM_MODEL=meta-llama/Llama-2-7b-hf
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEM=0.9  # GPU memory utilization (0.0-1.0)
VLLM_TRUST_REMOTE_CODE=true

# ExecutorTorch (engines-executorch profile) — Edge inference, pre-compiled models
# Model path: local dir or /models (mounted volume with .pte files)
EXECUTORCH_MODEL_PATH=/models
EXECUTORCH_DTYPE=float32  # float32, float16, bfloat16

# ── Build-time Security (Docker build args) ──────────────────────────────────
# REQUIRE_HASHES=true   (default) — enforce strict pip hash validation
#   ✓ Maximum security: binary hashes validated on every dependency
#   ✓ Required for supply-chain hardening
#   ✗ Requires platform-specific requirements.lock (regenerate if changing CPU arch)
#
# REQUIRE_HASHES=false  — disable pip hash validation
#   ✓ Flexible: works across CPU architectures (Linux, macOS, Windows)
#   ✗ Reduced security: dependencies not verified against known-good hashes
#   • Use only for dev/testing or when cross-platform compatibility is critical
#
# RECOMMENDATION:
#   - Production: REQUIRE_HASHES=true (regenerate lock for your platform)
#   - Dev on Mac: REQUIRE_HASHES=false (or regenerate lock: `uv pip compile`)
#   - CI/CD: REQUIRE_HASHES=true (lock is locked to CI platform)
#
REQUIRE_HASHES=true
